# Anthropic Claude API
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-...

# Claude モデル（書類解析用）
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# 国交省 不動産情報ライブラリ API
# https://www.reinfolib.mlit.go.jp/help/apiManual/ で申請
REINFOLIB_API_KEY=

# デモモード：APIキーがなくてもサンプルデータで動かす
DEMO_MODE=true

# ----------------------------------------------------
# 公開（ngrok）：社内チームに http(s) で共有したいとき
# ----------------------------------------------------
# 1. https://dashboard.ngrok.com/signup で無料アカウント作成（30秒）
# 2. https://dashboard.ngrok.com/get-started/your-authtoken でトークン取得
# 3. 下記にペースト
NGROK_AUTHTOKEN=

# Basic認証（推奨）：URLを知っていてもパスワードを知らないとアクセスできない
# 形式：username:password （例：team:abc123xyz）
NGROK_BASIC_AUTH=

# 固定ドメイン（任意）：ngrokの無料dev domainを使う場合
# 例：snowshoe-trance-badass.ngrok-free.dev
# 指定しなければ毎回ランダムURLになる
NGROK_DOMAIN=


